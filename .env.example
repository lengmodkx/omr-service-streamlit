# OMR Python 服务环境变量示例
# 复制为 .env 并填入实际值
# 这些配置也可放到 Nacos 配置中心：dataId=omr-service.yaml, group=DEFAULT_GROUP

# gRPC / Dubbo Triple 端口
OMR_DUBBO_PORT=20884
OMR_HEALTH_PORT=8080

# Nacos 注册中心 + 配置中心
NACOS_SERVER=39.153.154.183:8848
NACOS_NAMESPACE=8c4541fd-870e-414d-bdee-72cab49fe8d2
NACOS_USERNAME=nacos
NACOS_PASSWORD=lemon2judy
NACOS_SERVICE_NAME=omr-service
NACOS_GROUP_NAME=DEFAULT_GROUP
NACOS_CONFIG_DATA_ID=omr-service.yaml
NACOS_CONFIG_GROUP=DEFAULT_GROUP

# Redis（作为消息队列，替代 RabbitMQ）
REDIS_HOST=47.99.83.217
REDIS_PORT=6379
REDIS_PASSWORD=lemon2judy
REDIS_DB=4
REDIS_TIMEOUT=10
REDIS_SSL=false
REDIS_JOB_STREAM=omr:batch:job
REDIS_RESULT_STREAM=omr:batch:result

# 运行时
OMR_WORKER_COUNT=4
OMR_IMAGE_TIMEOUT=30
OMR_MAX_IMAGE_BYTES=52428800
